# === Configuración del Proyecto ===
# Copia este archivo a .env y actualiza los valores

# === BASE DE DATOS ===
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_contraseña_segura
DB_NAME=database_manager
DB_CHARSET=utf8mb4

# === API FASTAPI ===
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=4

# === SEGURIDAD ===
SECRET_KEY=tu_clave_secreta_muy_larga_y_random_aqui_12345678901234567890
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# === CORS ===
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000", "http://127.0.0.1:8000"]

# === QR CODES ===
QR_OUTPUT_DIR=./backend/qr_codes
QR_SIZE=300

# === LOGGING ===
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./backend/logs/app.log

# === IMPORTACIÓN ===
MAX_FILE_SIZE=52428800  # 50MB en bytes
MAX_ROWS_BATCH=1000
ALLOWED_EXTENSIONS=csv,xlsx,xls,txt,dat

# === NGINX (Si uses Docker) ===
NGINX_PORT=80
NGINX_SSL_PORT=443

# === MARIADB (Docker) ===
MARIADB_ROOT_PASSWORD=root_password
MARIADB_DATABASE=database_manager
MARIADB_USER=app_user
MARIADB_PASSWORD=app_password
LOG_LEVEL=INFO
