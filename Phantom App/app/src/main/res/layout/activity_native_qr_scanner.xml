<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#081421"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/scannerStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="12dp"
        android:text="Inicializando escáner..."
        android:textColor="#F2F7FB"
        android:textSize="16sp" />

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#000000"
        app:implementationMode="performance"
        app:scaleType="fillCenter" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="El código leído se enviará directamente al flujo QR del panel web."
        android:textColor="#B5C6D8"
        android:textSize="13sp" />

    <Button
        android:id="@+id/cancelScanButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Cancelar" />

</LinearLayout>